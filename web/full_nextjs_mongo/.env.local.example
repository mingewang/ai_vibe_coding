# ============================================================
# Environment Variables — Example File
# ============================================================
# Instructions:
#   1. Copy this file and rename to .env.local
#      (on Windows: copy .env.local.example .env.local)
#   2. Fill in your own values
#   3. Never share or commit .env.local
#
# How to get MONGODB_URI:
#   1. Go to MongoDB Atlas → Database → Connect → Drivers
#   2. Copy the connection string
#   3. Replace <username> and <password> with your credentials
#   4. Make sure the database name is "ecommerce"
#
# How to get JWT_SECRET:
#   Run this in terminal: openssl rand -base64 32
#   Or just type any long random string.
# ============================================================

COMRITE_CLOUD_MONGO_URL=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/ecommerce
JWT_SECRET=your-super-secret-key-change-this-in-production
NEXT_PUBLIC_APP_URL=http://localhost:3000
