# LLM API Configuration
# Choose one: "openai" or "deepseek"
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# For DeepSeek, uncomment and fill:
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Embedding model (uses sentence-transformers, runs locally)
# For users in China, set HF_ENDPOINT=https://hf-mirror.com
HF_ENDPOINT=
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5

# Web crawler settings
CRAWLER_MAX_DEPTH=2
CRAWLER_MAX_PAGES=50
CRAWLER_DELAY=1.0

# Vector store
VECTOR_STORE_PATH=./data/vector_store.faiss
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# RAG
TOP_K=5
